# Database
# Local Homebrew Postgres example (adjust user/db for your machine):
DATABASE_URL=postgresql+asyncpg://YOUR_USER@localhost:5432/dailybrief

# Redis
REDIS_URL=redis://localhost:6379/0

# API keys — sign up at each provider's developer portal
ANTHROPIC_API_KEY=          # https://console.anthropic.com — for AI summaries
NEWSAPI_KEY=                # https://newsapi.org — Bloomberg, WSJ, FT, TechCrunch, etc.
GUARDIAN_API_KEY=           # https://open-platform.theguardian.com — Guardian content
X_API_BEARER_TOKEN=         # https://developer.x.com — X/Twitter tracker (paid tier)

# App
API_KEY=change-me-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# Scheduler intervals (seconds)
X_REFRESH_INTERVAL=300
RSS_REFRESH_INTERVAL=900
AGGREGATOR_REFRESH_INTERVAL=900
